FINNHUB_API_KEY=
OPENROUTER_API_KEY=
SEC_USER_AGENT=squeeze-finder your-email@example.com

# comma-separated list of allowed origins; required for the Vercel frontend
# to call the API. localhost defaults are applied when unset.
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# set to 0 to disable background scan prewarm on server startup
# SQUEEZE_PREWARM=1

# deferred — add when enabling Reddit sentiment source
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=squeeze-finder/0.1 by <your-reddit-username>

# optional
# OPENFDA_API_KEY=
